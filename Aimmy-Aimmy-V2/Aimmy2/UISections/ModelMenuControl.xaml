<UserControl x:Class="Aimmy2.Controls.ModelMenuControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3FFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#5FFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <ScrollViewer x:Name="ModelMenu"
                  VerticalScrollBarVisibility="Disabled"
                  PanningMode="VerticalOnly">
        <Grid>
            <Border Background="#12FFFFFF"
                    BorderBrush="#28FFFFFF"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="10,0,10,8"
                    VerticalAlignment="Top"
                    Height="52">
                <Grid Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Margin="0,1,12,0">
                        <TextBlock Text="&#xE8B7;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="#F2FFFFFF"
                                   FontSize="13"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Local library"
                                       Foreground="#F2FFFFFF"
                                       FontFamily="{DynamicResource Atkinson Hyperlegible}"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="Drag in models or configs, then refresh the list"
                                       Foreground="#99FFFFFF"
                                       FontFamily="{DynamicResource Atkinson Hyperlegible}"
                                       FontSize="10"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,0,0">
                        <Button x:Name="OpenModelsButton"
                                Content="&#xE8B7;"
                                ToolTip="Open Models Folder"
                                Style="{StaticResource IconButtonStyle}"
                                FontSize="16"
                                Margin="0,0,8,0"
                                Click="OpenModelsButton_Click" />
                        <Button x:Name="OpenConfigsButton"
                                Content="&#xE713;"
                                ToolTip="Open Configs Folder"
                                Style="{StaticResource IconButtonStyle}"
                                FontSize="16"
                                Margin="0,0,8,0"
                                Click="OpenConfigsButton_Click" />
                        <Button x:Name="RefreshLocalButton"
                                Content="&#xE72C;"
                                ToolTip="Refresh Local List"
                                Style="{StaticResource IconButtonStyle}"
                                FontSize="16"
                                Margin="0,0,0,0"
                                Click="RefreshLocalButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>
            <TabControl HorizontalContentAlignment="Left"
                        Margin="10,64,10,0"
                        Style="{StaticResource ModelsTabControl}">
                <TabItem Style="{StaticResource ModelsTabItem}"
                         Height="33">
                    <TabItem.Header>
                        <TextBlock Text="Local Models"
                                   FontSize="11"
                                   Foreground="#F2FFFFFF"
                                   FontFamily="{DynamicResource Atkinson Hyperlegible}" />
                    </TabItem.Header>
                    <Grid>
                        <ScrollViewer x:Name="LocalModelStoreMenu"
                                      VerticalScrollBarVisibility="Visible"
                                      PanningMode="VerticalOnly"
                                      Margin="0,10,-6,0">
                            <StackPanel>
                                <Border Background="#3F3C3C3C"
                                BorderBrush="#3FFFFFFF"
                                BorderThickness="1"
                                CornerRadius="5,5,0,0"
                                Margin="0,0,0,0"
                                Height="39">
                                    <TextBox
                                x:Name="LocalModelSearchBox"
                                FontFamily="{DynamicResource Atkinson Hyperlegible}"
                                Padding="5"
                                Foreground="#F2FFFFFF"
                                CaretBrush="White"
                                TextChanged="LocalModelSearchBox_TextChanged">
                                    </TextBox>
                                </Border>
                                <StackPanel x:Name="LocalModelStoreScroller" />
                            </StackPanel>
                        </ScrollViewer>
                        <Border Background="#3F3C3C3C"
                                BorderBrush="#3FFFFFFF"
                                BorderThickness="1"
                                Margin="0,55,0,54">
                            <ListBox x:Name="ModelListBox"
                                     AllowDrop="True"
                                     Drop="ModelListBox_Drop"
                                     DragOver="ModelListBox_DragOver"
                                     Foreground="#F2FFFFFF"
                                     FontFamily="{DynamicResource Atkinson Hyperlegible}"
                                     Margin="0"
                                     Padding="2">
                            </ListBox>
                        </Border>
                        <Border Background="#3F3C3C3C"
                                BorderBrush="#3FFFFFFF"
                                BorderThickness="1"
                                CornerRadius="0,0,0,5"
                                Margin="0,0,44,10"
                                VerticalAlignment="Bottom"
                                Height="39">
                            <Label x:Name="SelectedModelNotifier"
                                   Foreground="#F2FFFFFF"
                                   Content="Loaded Model: N/A"
                                   FontFamily="{DynamicResource Atkinson Hyperlegible}"
                                   Padding="10"></Label>
                        </Border>
                        <Button x:Name="OpenFolderB_ModelWindow"
                                Background="#3F3C3C3C"
                                BorderBrush="#3FFFFFFF"
                                Content="&#xE838;"
                                HorizontalAlignment="Right"
                                Height="39"
                                Width="39"
                                Margin="0,0,0,10"
                                VerticalAlignment="Bottom"
                                Padding="0,0,0,0"
                                FontFamily="Segoe MDL2 Assets"
                                BorderThickness="1"
                                materialDesign:ButtonAssist.CornerRadius="0,0,5,0"
                                FontSize="13"
                                Foreground="#F2FFFFFF"
                                Click="OpenFolderB_Click"
                                Tag="models" />
                    </Grid>
                </TabItem>
                <TabItem Style="{StaticResource ModelsTabItem}"
                         Height="33"
                         Width="90">
                    <TabItem.Header>
                        <TextBlock Text="Local Configs"
                                   FontSize="11"
                                   Foreground="#F2FFFFFF"
                                   FontFamily="{DynamicResource Atkinson Hyperlegible}" />
                    </TabItem.Header>
                    <Grid>
                        <ScrollViewer x:Name="LocalConfigStoreMenu"
                              VerticalScrollBarVisibility="Visible"
                              PanningMode="VerticalOnly"
                              Margin="0,10,-6,0">
                            <StackPanel>
                                <Border Background="#3F3C3C3C"
                                    BorderBrush="#3FFFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="5,5,0,0"
                                    Margin="0,0,0,0"
                                    Height="39">
                                    <TextBox
                                        x:Name="LocalConfigSearchBox"
                                        FontFamily="{DynamicResource Atkinson Hyperlegible}"
                                        Padding="5"
                                        Foreground="#F2FFFFFF"
                                        CaretBrush="White"
                                        TextChanged="LocalConfigSearchBox_TextChanged">
                                    </TextBox>
                                </Border>
                                <StackPanel x:Name="LocalConfigStoreScroller" />
                            </StackPanel>
                        </ScrollViewer>
                        <Border Background="#3F3C3C3C"
                                BorderBrush="#3FFFFFFF"
                                BorderThickness="1"
                                Margin="0,55,0,54">
                            <ListBox x:Name="ConfigsListBox"
                                     AllowDrop="True"
                                     Drop="ConfigsListBox_Drop"
                                     DragOver="ConfigsListBox_DragOver"
                                     Foreground="#F2FFFFFF"
                                     FontFamily="{DynamicResource Atkinson Hyperlegible}"
                                     Margin="0"
                                     Padding="2" />
                        </Border>
                        <Border Background="#3F3C3C3C"
                                BorderBrush="#3FFFFFFF"
                                BorderThickness="1"
                                CornerRadius="0,0,0,5"
                                Margin="0,0,44,10"
                                VerticalAlignment="Bottom"
                                Height="39">
                            <Label x:Name="SelectedConfigNotifier"
                                   Foreground="#F2FFFFFF"
                                   Content="Loaded Config: N/A"
                                   FontFamily="{DynamicResource Atkinson Hyperlegible}"
                                   Padding="10"></Label>
                        </Border>
                        <Button x:Name="OpenFolderB_ConfigWindow"
                                Background="#3F3C3C3C"
                                BorderBrush="#3FFFFFFF"
                                Content="&#xE838;"
                                HorizontalAlignment="Right"
                                Height="39"
                                Width="39"
                                Margin="0,0,0,10"
                                VerticalAlignment="Bottom"
                                Padding="0,0,0,0"
                                FontFamily="Segoe MDL2 Assets"
                                BorderThickness="1"
                                materialDesign:ButtonAssist.CornerRadius="0,0,5,0"
                                FontSize="13"
                                Foreground="#F2FFFFFF"
                                Click="OpenFolderB_Click"
                                Tag="configs" />
                    </Grid>
                </TabItem>
                <TabItem Style="{StaticResource ModelsTabItem}"
                         Height="33"
                         Width="132">
                    <TabItem.Header>
                        <TextBlock Text="Downloadable Models"
                                   FontSize="11"
                                   Foreground="#F2FFFFFF"
                                   FontFamily="{DynamicResource Atkinson Hyperlegible}" />
                    </TabItem.Header>
                    <Grid>
                        <Label x:Name="LackOfModelsText"
                               Visibility="Collapsed"
                               HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center"
                               Content="There is no downloadable models at the moment, please check again later."
                               Foreground="#F2FFFFFF" />
                        <ScrollViewer x:Name="ModelStoreMenu"
                                      VerticalScrollBarVisibility="Visible"
                                      PanningMode="VerticalOnly"
                                      Margin="0,10,0,0">
                            <StackPanel>
                                <Border Background="#3F3C3C3C"
                                        BorderBrush="#3FFFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="5,5,0,0"
                                        Margin="0,0,5,10"
                                        Height="39">
                                    <TextBox
                                        x:Name="SearchBox"
                                        FontFamily="{DynamicResource Atkinson Hyperlegible}"
                                        Padding="5"
                                        Foreground="#F2FFFFFF"
                                        CaretBrush="White"
                                        TextChanged="SearchBox_TextChanged">
                                    </TextBox>
                                </Border>
                                <StackPanel x:Name="ModelStoreScroller" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
                <TabItem Style="{StaticResource ModelsTabItem}"
                         Height="33"
                         Width="132">
                    <TabItem.Header>
                        <TextBlock Text="Downloadable Configs"
                                   FontSize="11"
                                   Foreground="#F2FFFFFF"
                                   FontFamily="{DynamicResource Atkinson Hyperlegible}" />
                    </TabItem.Header>
                    <Grid>
                        <Label x:Name="LackOfConfigsText"
                               Visibility="Collapsed"
                               HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center"
                               Content="There is no downloadable configs at the moment, please check again later."
                               Foreground="#F2FFFFFF" />
                        <ScrollViewer x:Name="ConfigStoreMenu"
                                      VerticalScrollBarVisibility="Visible"
                                      PanningMode="VerticalOnly"
                                      Margin="0,10,0,0">
                            <StackPanel>
                                <Border Background="#3F3C3C3C"
                                        BorderBrush="#3FFFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="5,5,0,0"
                                        Margin="0,0,5,10"
                                        Height="39">
                                    <TextBox
                                        x:Name="CSearchBox"
                                        FontFamily="{DynamicResource Atkinson Hyperlegible}"
                                        Padding="5"
                                        Foreground="#F2FFFFFF"
                                        CaretBrush="White"
                                        TextChanged="CSearchBox_TextChanged">
                                    </TextBox>
                                </Border>
                                <StackPanel x:Name="ConfigStoreScroller" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </ScrollViewer>
</UserControl>
