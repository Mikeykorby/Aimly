<UserControl x:Class="Aimmy2.UILibrary.ASlider"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:Ant="clr-namespace:AntWpf.Controls;assembly=AntWpf"
             xmlns:local="clr-namespace:Aimmy2.UILibrary"
             xmlns:theme="clr-namespace:Aimmy2.Theme"
             theme:ThemeBehavior.AutoRegister="True"
             mc:Ignorable="d"
             HorizontalAlignment="Stretch"
             Height="70">
    <Grid>
        <Border x:Name="SliderBorder"
                Height="70"
                Background="#2F3A3A3A"
                CornerRadius="00"
                BorderThickness="1,0,1,0"
                BorderBrush="#26FFFFFF">
            <Grid>
                <Label x:Name="SliderTitle"
                       Padding="10,10,10,10"
                       FontFamily="{DynamicResource Atkinson Hyperlegible}"
                       Content="Mouse Sensitivity"
                       Foreground="#F2FFFFFF"
                       VerticalContentAlignment="Center"
                       FontSize="13"
                       VerticalAlignment="Top"
                       Height="40"
                       HorizontalAlignment="Left" />
                <Label x:Name="AdjustNotifier"
                       Padding="10,10,10,10"
                       FontFamily="{DynamicResource Atkinson Hyperlegible}"
                       Content="0.95 Sensitivity"
                       Foreground="#F2FFFFFF"
                       VerticalContentAlignment="Center"
                       FontSize="13"
                       VerticalAlignment="Top"
                       Height="40"
                       HorizontalAlignment="Right"
                       HorizontalContentAlignment="Right"
                       Margin="0,0,10,0" />
                <Slider x:Name="Slider"
                        Margin="35,40,35,0"
                        VerticalAlignment="Top"
                        Foreground="#F2FFFFFF"
                        IsSnapToTickEnabled="True"
                        Value="2"
                        TickFrequency="0.01" />
                <Ant:Button x:Name="SubtractOne"
                            Tag="Theme:Background"
                            BorderBrush="{x:Null}"
                            EffectBrush="{x:Null}"
                            Content="&#xE949;"
                            HorizontalAlignment="Left"
                            Height="20"
                            Width="20"
                            Margin="10,0,0,10"
                            VerticalAlignment="Bottom"
                            Padding="0,0,0,0"
                            FontFamily="Segoe MDL2 Assets"
                            BorderThickness="0,0,0,0"
                            FontSize="10"
                            Foreground="#F2FFFFFF" />
                <Ant:Button x:Name="AddOne"
                            Tag="Theme:Background"
                            BorderBrush="{x:Null}"
                            EffectBrush="{x:Null}"
                            Content="&#xE948;"
                            HorizontalAlignment="Right"
                            Height="20"
                            Width="20"
                            Margin="0,0,10,10"
                            VerticalAlignment="Bottom"
                            Padding="0,0,0,0"
                            FontFamily="Segoe MDL2 Assets"
                            BorderThickness="0,0,0,0"
                            FontSize="10"
                            Foreground="#F2FFFFFF" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
