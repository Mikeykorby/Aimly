<UserControl x:Class="UILibrary.ADropdown"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:Ant="clr-namespace:AntWpf.Controls;assembly=AntWpf"
             xmlns:local="clr-namespace:UILibrary"
             mc:Ignorable="d"
             d:DesignWidth="282.5"
             Height="80">
    <Grid>
        <Border x:Name="DropdownBorder"
                Height="80"
                CornerRadius="0,0,6,6"
                BorderThickness="1,0,1,0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#2F3A3A3A"/>
                    <Setter Property="BorderBrush" Value="#26FFFFFF"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#3F4A4A4A"/>
                            <Setter Property="BorderBrush" Value="#46FFFFFF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Label x:Name="DropdownTitle"
                       Padding="10,10,10,10"
                       FontFamily="{DynamicResource Atkinson Hyperlegible}"
                       Content="Prediction Method"
                       Foreground="#F2FFFFFF"
                       VerticalContentAlignment="Center"
                       FontSize="13"
                       VerticalAlignment="Top"
                       Height="40" />
                <ComboBox x:Name="DropdownBox"
                          Height="30"
                          Margin="10,0,10,10"
                          VerticalAlignment="Bottom"
                          Foreground="#F2FFFFFF"
                          Ant:Input.PlaceholderBrush="#FFC8C8C8"
                          BorderBrush="#3FFFFFFF"
                          Padding="5,0,5,0"
                          BorderThickness="1,1,1,1"
                          Background="{x:Null}"
                          SelectedIndex="0"
                          FontFamily="{DynamicResource Atkinson Hyperlegible}"
                          SelectionChanged="DropdownBox_SelectionChanged">
                </ComboBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
