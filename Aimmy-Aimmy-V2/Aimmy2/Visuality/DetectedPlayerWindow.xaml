<Window x:Class="Visuality.DetectedPlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Visuality"
        mc:Ignorable="d"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized"
        Topmost="True"
        Focusable="False"
        ShowInTaskbar="False"
        Closing="Window_Closing"
        ResizeMode="NoResize"
        IsTabStop="False">
    <Grid>
        <!-- The sharp bounding box matching the video -->
        <Border x:Name="DetectedPlayerFocus"
                Style="{x:Null}"
                BorderThickness="1"
                BorderBrush="#CCFFFFFF"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Visibility="Visible"
                Opacity="0"
                CornerRadius="0">
            <Grid ClipToBounds="False">
                <TextBlock x:Name="DetectedPlayerConfidence"
                           Style="{x:Null}"
                           Margin="-9, -18, 0, 0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           Foreground="White"
                           FontSize="11"
                           FontFamily="Segoe UI"
                           FontWeight="Bold"
                           Opacity="0"
                           Text="0.37"/>
                
                <!-- Vertical bar background track -->
                <Canvas x:Name="ConfidenceBarContainer"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        Margin="-10,0,0,0"
                        Width="20"
                        Opacity="0"
                        ClipToBounds="False">
                    
                    <Border x:Name="ConfidenceTrack"
                            Width="2"
                            Background="#55FFFFFF"
                            Height="{Binding ActualHeight, ElementName=DetectedPlayerFocus}"
                            Canvas.Left="4"
                            Canvas.Top="0"/>

                    <!-- Vertical filling line -->
                    <Border x:Name="ConfidenceFill"
                            Style="{x:Null}"
                            Width="2"
                            Background="White"
                            Canvas.Left="4"/>

                    <!-- Horizontal thumb -->
                    <Border x:Name="ConfidenceThumb"
                            Style="{x:Null}"
                            Width="8"
                            Height="3"
                            Background="White"
                            Canvas.Left="1"/>
                </Canvas>
            </Grid>
        </Border>


        <!-- Tracers -->
        <Line x:Name="DetectedTracers"
              X1="0" Y1="0" X2="10" Y2="10"
              Stroke="Red"
              StrokeThickness="1"
              Opacity="0">
            <Line.Effect>
                <DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="0" Opacity="0.8"/>
            </Line.Effect>
        </Line>

        <!-- Aim Point -->
        <Ellipse x:Name="AimPoint"
                 Width="6" Height="6"
                 Fill="Red"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="0,0,0,0"
                 Opacity="0">
        </Ellipse>
    </Grid>
</Window>